<Page x:Class="PracticeAccountingApp.Pages.GroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource PrimaryBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Группы" Style="{StaticResource PageTitleText}"/>

        <!-- Панель действий -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="16">
            <StackPanel Orientation="Horizontal">
                <Button Content="Добавить группу" 
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding OpenAddCommand}"
                        Visibility="{Binding CanManageGroupsAndStudents, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Карточки групп -->
        <ListView Grid.Row="2" ItemsSource="{Binding Groups}"
                  Background="Transparent" BorderThickness="0"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>

            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" Value="10"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="360" Height="175" Style="{StaticResource CardStyle}" Padding="18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="{Binding GroupNumber}" FontSize="18" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Grid.Row="1" Text="{Binding Specialization}" 
                                       Foreground="{StaticResource TextBrush}" Margin="0,6,0,4"/>
                            <TextBlock Grid.Row="2" Text="{Binding StudentsCount, StringFormat='Студентов: {0}'}"
                                       Foreground="{StaticResource MutedTextBrush}"/>

                            <!-- Кнопка Удалить (только для Админа) -->
                            <Button Grid.Row="3" Content="🗑" 
                                    Style="{StaticResource GhostButton}"
                                    FontSize="18"
                                    Width="32" Height="32"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Visibility="{Binding DataContext.CanManageGroupsAndStudents, 
                                                RelativeSource={RelativeSource AncestorType=ListView}, 
                                                Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding DataContext.DeleteCommand, 
                                             RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>