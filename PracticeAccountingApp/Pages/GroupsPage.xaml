<Page x:Class="PracticeAccountingApp.Pages.GroupsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,20">

            <TextBlock Text="Группы"
                       FontSize="24"
                       FontWeight="SemiBold"/>

        </DockPanel>

        <DataGrid Grid.Row="1"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="Код группы"
                                    Width="200"/>

                <DataGridTextColumn Header="Специальность"
                                    Width="*"/>

                <DataGridTextColumn Header="Количество студентов"
                                    Width="200"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Page>