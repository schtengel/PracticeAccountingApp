<Page x:Class="PracticeAccountingApp.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="25">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Главная"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>

                <TextBlock Text="Обзор системы учета практик"
                           FontSize="14"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>

            <!-- STATS -->
            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,10,0,25">

                <Border Background="{StaticResource SecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Группы" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding GroupsCount}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Студенты" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding StudentsCount}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Практики" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding PracticesCount}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Background="{StaticResource SecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="8"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Отчеты" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding ReportsCount}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- LAST STATEMENTS (CARDS) -->
            <Border Grid.Row="2"
                    Background="{StaticResource SecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,0,0,20">

                <StackPanel>

                    <TextBlock Text="Последние ведомости"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,0,10"/>

                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Disabled">

                        <ItemsControl ItemsSource="{Binding LastStatements}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="240"
                                            Height="130"
                                            Margin="8"
                                            Background="{StaticResource BackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="12">

                                        <StackPanel>

                                            <TextBlock Text="{Binding GroupName}"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       FontSize="12"/>

                                            <TextBlock Text="{Binding PracticeName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"
                                                       Margin="0,6,0,0"/>

                                            <TextBlock Text="{Binding TeacherName}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Margin="0,4,0,0"/>

                                            <TextBlock Text="{Binding Date}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Margin="0,4,0,0"/>

                                        </StackPanel>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </ScrollViewer>

                </StackPanel>

            </Border>

            <!-- BOTTOM -->
            <Grid Grid.Row="3">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- UPCOMING PRACTICES -->
                <Border Grid.Column="0"
                        Background="{StaticResource SecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="0,0,10,0"
                        Padding="16">

                    <StackPanel>

                        <TextBlock Text="Ближайшие практики (1 месяц)"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding UpcomingPractices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220"
                                            Height="90"
                                            Margin="6"
                                            Background="{StaticResource BackgroundBrush}"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10">

                                        <StackPanel>
                                            <TextBlock Text="{Binding PracticeName}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextBrush}"/>

                                            <TextBlock Text="{Binding Group}"
                                                       Foreground="{StaticResource MutedTextBrush}"/>

                                            <TextBlock Text="{Binding StartDate}"
                                                       Foreground="{StaticResource AccentBrush}"/>
                                        </StackPanel>

                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>

                </Border>

                <!-- LAST ACTIONS -->
                <Border Grid.Column="1"
                        Background="{StaticResource SecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Margin="10,0,0,0"
                        Padding="16">

                    <StackPanel>

                        <TextBlock Text="Последние действия"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,10"/>

                        <ListView ItemsSource="{Binding LastActions}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Foreground="{StaticResource TextBrush}"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</Page>