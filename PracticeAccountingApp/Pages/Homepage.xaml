<Page x:Class="PracticeAccountingApp.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#D9BC9A">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="25">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="350"/>
                <RowDefinition Height="250"/>
            </Grid.RowDefinitions>

            <StackPanel>

                <TextBlock Text="Главная"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#403B35"/>

                <TextBlock Text="Обзор системы учета практик"
                           FontSize="14"
                           Margin="0,5,0,0"
                           Foreground="#595144"/>

            </StackPanel>


            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,25,0,25">

                <Border Background="#403B35"
                        CornerRadius="16"
                        Margin="8">

                    <StackPanel Margin="20">

                        <TextBlock Text="Группы"
                                   FontSize="14"
                                   Foreground="#BF996A"/>

                        <TextBlock Text="24"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                    </StackPanel>

                </Border>

                <Border Background="#403B35"
                        CornerRadius="16"
                        Margin="8">

                    <StackPanel Margin="20">

                        <TextBlock Text="Студенты"
                                   FontSize="14"
                                   Foreground="#BF996A"/>

                        <TextBlock Text="380"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                    </StackPanel>

                </Border>

                <Border Background="#403B35"
                        CornerRadius="16"
                        Margin="8">

                    <StackPanel Margin="20">

                        <TextBlock Text="Практики"
                                   FontSize="14"
                                   Foreground="#BF996A"/>

                        <TextBlock Text="112"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                    </StackPanel>

                </Border>

                <Border Background="#403B35"
                        CornerRadius="16"
                        Margin="8">

                    <StackPanel Margin="20">

                        <TextBlock Text="Ведомости"
                                   FontSize="14"
                                   Foreground="#BF996A"/>

                        <TextBlock Text="17"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                    </StackPanel>

                </Border>

            </UniformGrid>

            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="16"
                    Padding="20"
                    Margin="0,0,0,20">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Последние ведомости"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#403B35"/>

                    <DataGrid Grid.Row="1"
                              Margin="0,15,0,0"
                              AutoGenerateColumns="False"
                              RowHeight="35">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Группа"
                                                Width="120"/>

                            <DataGridTextColumn Header="Практика"
                                                Width="*"/>

                            <DataGridTextColumn Header="Организация"
                                                Width="*"/>

                            <DataGridTextColumn Header="Дата"
                                                Width="120"/>

                            <DataGridTextColumn Header="Статус"
                                                Width="120"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <Grid Grid.Row="3">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="16"
                        Margin="0,0,10,0"
                        Padding="20">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Ближайшие практики"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <ListView Grid.Row="1"
                                  Margin="0,15,0,0">

                            <ListViewItem>
                                ИС131 — Производственная практика
                            </ListViewItem>

                            <ListViewItem>
                                ИС132 — Учебная практика
                            </ListViewItem>

                            <ListViewItem>
                                ПБ141 — Производственная практика
                            </ListViewItem>

                        </ListView>

                    </Grid>

                </Border>


                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="16"
                        Margin="10,0,0,0"
                        Padding="20">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Последние действия"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <ListView Grid.Row="1"
                                  Margin="0,15,0,0">

                            <ListViewItem>
                                Создана ведомость ИС131
                            </ListViewItem>

                            <ListViewItem>
                                Добавлен студент Иванов И.И.
                            </ListViewItem>

                            <ListViewItem>
                                Обновлена практика ПП-2026
                            </ListViewItem>

                            <ListViewItem>
                                Добавлена организация ООО НМК
                            </ListViewItem>

                        </ListView>

                    </Grid>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</Page>

