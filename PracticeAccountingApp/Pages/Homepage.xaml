<Page x:Class="PracticeAccountingApp.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#D9BC9A">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="25">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="350"/>
                <RowDefinition Height="250"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel>

                <TextBlock Text="Главная"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#403B35"/>

                <TextBlock Text="Обзор системы учета практик"
                           FontSize="14"
                           Margin="0,5,0,0"
                           Foreground="#595144"/>

            </StackPanel>

            <!-- STATS -->
            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,25,0,25">

                <Border Background="#403B35" CornerRadius="16" Margin="8">
                    <StackPanel Margin="20">
                        <TextBlock Text="Группы" Foreground="#BF996A"/>
                        <TextBlock Text="{Binding GroupsCount}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#403B35" CornerRadius="16" Margin="8">
                    <StackPanel Margin="20">
                        <TextBlock Text="Студенты" Foreground="#BF996A"/>
                        <TextBlock Text="{Binding StudentsCount}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#403B35" CornerRadius="16" Margin="8">
                    <StackPanel Margin="20">
                        <TextBlock Text="Практики" Foreground="#BF996A"/>
                        <TextBlock Text="{Binding PracticesCount}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#403B35" CornerRadius="16" Margin="8">
                    <StackPanel Margin="20">
                        <TextBlock Text="Отчеты" Foreground="#BF996A"/>
                        <TextBlock Text="{Binding ReportsCount}"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- TABLE -->
            <Border Grid.Row="2"
                    Background="White"
                    CornerRadius="16"
                    Padding="20">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Последние ведомости"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#403B35"/>

                    <DataGrid Grid.Row="1"
                              Margin="0,15,0,0"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              ItemsSource="{Binding LastStatements}">

                        <DataGrid.Columns>

                            <DataGridTextColumn Header="Группа"
                                                Binding="{Binding GroupName}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Практика"
                                                Binding="{Binding PracticeName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Организация"
                                                Binding="{Binding OrganizationName}"
                                                Width="*"/>

                            <DataGridTextColumn Header="Дата"
                                                Binding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                                Width="120"/>

                            <DataGridTextColumn Header="Статус"
                                                Binding="{Binding Status}"
                                                Width="120"/>

                        </DataGrid.Columns>

                    </DataGrid>

                </Grid>

            </Border>

            <!-- BOTTOM -->
            <Grid Grid.Row="3">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="16"
                        Margin="0,0,10,0"
                        Padding="20">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Ближайшие практики"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#403B35"/>

                        <ListView Grid.Row="1"
                                  Margin="0,15,0,0"
                                  ItemsSource="{Binding UpcomingPractices}"/>
                    </Grid>

                </Border>

                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="16"
                        Margin="10,0,0,0"
                        Padding="20">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Последние действия"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#403B35"/>

                        <ListView Grid.Row="1"
                                  Margin="0,15,0,0"
                                  ItemsSource="{Binding LastActions}"/>
                    </Grid>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</Page>