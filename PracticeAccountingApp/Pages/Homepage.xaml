<Page x:Class="PracticeAccountingApp.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource PrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Style="{StaticResource ModernScrollViewer}">
        <Grid Margin="28,28,28,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Главная" Style="{StaticResource PageTitleText}" Margin="0"/>
                <TextBlock Text="Обзор системы учёта практик"
                           FontSize="14" 
                           Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>

            <!-- Карточки статистики -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,24">

                <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="👥" FontSize="22" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding GroupsCount}"
                                   FontSize="38" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Групп"
                                   FontSize="13" Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="5,0,5,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="🎓" FontSize="22" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding StudentsCount}"
                                   FontSize="38" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Студентов"
                                   FontSize="13" Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="5,0,5,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📚" FontSize="22" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding PracticesCount}"
                                   FontSize="38" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Ведомостей"
                                   FontSize="13" Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="10,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="📄" FontSize="22" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding ReportsCount}"
                                   FontSize="38" FontWeight="Bold"
                                   Foreground="{StaticResource TextBrush}"/>
                        <TextBlock Text="Отчётов"
                                   FontSize="13" Margin="0,4,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Последние ведомости -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="Последние ведомости"
                               Style="{StaticResource SectionTitleText}"/>
                    <ItemsControl ItemsSource="{Binding LastStatements}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240" Margin="0,0,12,12"
                                        Background="{StaticResource SurfaceBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="12" Padding="16">
                                    <StackPanel>
                                        <Border Style="{StaticResource BadgeStyle}" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding GroupName}"
                                                       Style="{StaticResource BadgeText}"/>
                                        </Border>
                                        <TextBlock Text="{Binding PracticeName}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   Foreground="{StaticResource TextBrush}"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding TeacherName}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="13" Margin="0,6,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Date, StringFormat='dd.MM.yyyy'}"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   FontSize="12" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Нижняя секция: ближайшие + действия -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Ближайшие практики -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Ближайшие практики (30 дней)"
                                   Style="{StaticResource SectionTitleText}"/>
                        <ItemsControl ItemsSource="{Binding UpcomingPractices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8" Padding="14,12"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding PracticeName}"
                                                           FontWeight="SemiBold" FontSize="14"
                                                           Foreground="{StaticResource TextBrush}"/>
                                                <TextBlock Text="{Binding Group}"
                                                           FontSize="13"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Style="{StaticResource BadgeStyle}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding StartDate, StringFormat='dd.MM.yyyy'}"
                                                           Style="{StaticResource BadgeText}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Последние действия — исправлен ItemTemplate -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Последние действия"
                                   Style="{StaticResource SectionTitleText}"/>
                        <ItemsControl ItemsSource="{Binding LastActions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,10"
                                            BorderBrush="{StaticResource DividerBrush}"
                                            BorderThickness="0,0,0,1">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Margin="0,0,10,0"
                                                     Fill="{StaticResource AccentBrush}"
                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource TextBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
