<Page x:Class="PracticeAccountingApp.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource PrimaryBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <StackPanel Margin="0,0,0,24">
                <TextBlock Text="Главная" Style="{StaticResource PageTitleText}"/>
                <TextBlock Text="Обзор системы учета практик" 
                           FontSize="15" Foreground="{StaticResource MutedTextBrush}"/>
            </StackPanel>

            <!-- STATISTICS -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,28">
                <Border Style="{StaticResource CardStyle}" Margin="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Группы" FontSize="14" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding GroupsCount}" FontSize="36" FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Студенты" FontSize="14" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding StudentsCount}" FontSize="36" FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Ведомости" FontSize="14" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding PracticesCount}" FontSize="36" FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="8" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Отчеты" FontSize="14" Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="{Binding ReportsCount}" FontSize="36" FontWeight="Bold" 
                                   Foreground="{StaticResource TextBrush}" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- LAST STATEMENTS -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="20">
                <StackPanel>
                    <TextBlock Text="Последние ведомости" Style="{StaticResource SectionTitleText}"/>
                    <ItemsControl ItemsSource="{Binding LastStatements}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="255" Height="138" Margin="8" 
                                        Background="{StaticResource PrimaryBrush}"
                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                        CornerRadius="14" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="{Binding GroupName}" Foreground="{StaticResource AccentBrush}" FontSize="13"/>
                                        <TextBlock Text="{Binding PracticeName}" FontWeight="SemiBold" 
                                                   FontSize="15" Margin="0,8,0,4" Foreground="{StaticResource TextBrush}"/>
                                        <TextBlock Text="{Binding TeacherName}" Foreground="{StaticResource MutedTextBrush}"/>
                                        <TextBlock Text="{Binding Date, StringFormat='dd.MM.yyyy'}" 
                                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- BOTTOM SECTION -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <!-- UPCOMING -->
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,12,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Ближайшие практики" Style="{StaticResource SectionTitleText}"/>
                        <ItemsControl ItemsSource="{Binding UpcomingPractices}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="235" Height="105" Margin="6" 
                                            Background="{StaticResource PrimaryBrush}"
                                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="12" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="{Binding PracticeName}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Group}" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding StartDate, StringFormat='dd.MM.yyyy'}" 
                                                       Foreground="{StaticResource AccentBrush}" Margin="0,8,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- LAST ACTIONS -->
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Последние действия" Style="{StaticResource SectionTitleText}"/>
                        <ListView ItemsSource="{Binding LastActions}" Background="Transparent" 
                                  BorderThickness="0" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>