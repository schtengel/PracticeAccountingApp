<Page x:Class="PracticeAccountingApp.Pages.PracticesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource PrimaryBrush}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ведомости практик" Style="{StaticResource PageTitleText}"/>

        <!-- Action Bar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="16">
            <StackPanel Orientation="Horizontal">
                <TextBox Width="380" Style="{StaticResource InputBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Добавить ведомость" 
                        Margin="20,0,0,0"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding OpenAddCommand}"
                        Visibility="{Binding CanManagePractices, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </Border>

        <!-- Табличный список с кнопками действий -->
        <ListView Grid.Row="2" ItemsSource="{Binding Practices}"
                  Background="{StaticResource PrimaryBrush}"
                  BorderThickness="0">

            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Тип практики" Width="220" DisplayMemberBinding="{Binding PracticeType}"/>
                    <GridViewColumn Header="Модуль" Width="200" DisplayMemberBinding="{Binding ModuleName}"/>
                    <GridViewColumn Header="Группа" Width="110" DisplayMemberBinding="{Binding Group}"/>
                    <GridViewColumn Header="Преподаватель" Width="180" DisplayMemberBinding="{Binding TeacherName}"/>
                    <GridViewColumn Header="Начало" Width="100" DisplayMemberBinding="{Binding Start, StringFormat=dd.MM.yyyy}"/>
                    <GridViewColumn Header="Окончание" Width="100" DisplayMemberBinding="{Binding End, StringFormat=dd.MM.yyyy}"/>

                    <!-- Колонка с действиями -->
                    <GridViewColumn Header="Действия" Width="140">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <!-- Кнопка Изменить -->
                                    <Button Content="Изменить" 
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="8,4"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding DataContext.CanManagePractices, 
                                                        RelativeSource={RelativeSource AncestorType=ListView}, 
                                                        Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.EditCommand, 
                                                     RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"/>

                                    <!-- Кнопка Удалить -->
                                    <Button Content="Удалить" 
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,4"
                                            Visibility="{Binding DataContext.CanManagePractices, 
                                                        RelativeSource={RelativeSource AncestorType=ListView}, 
                                                        Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.DeleteCommand, 
                                                     RelativeSource={RelativeSource AncestorType=ListView}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>

            <!-- Двойной клик для редактирования -->
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Cursor" Value="Hand"/>
                    <EventSetter Event="MouseDoubleClick" Handler="ListViewItem_MouseDoubleClick"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>
    </Grid>
</Page>