<Page x:Class="PracticeAccountingApp.Pages.PracticesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Практики"
                   FontSize="24"
                   FontWeight="SemiBold"/>

        <DataGrid Grid.Row="1"
                  Margin="0,20,0,0"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="№ п/п"
                    Width="2*"/>

                <DataGridTextColumn Header="Вид практики"
                    Width="2*"/>

                <DataGridTextColumn Header="Название"
                                    Width="2*"/>

                <DataGridTextColumn Header="Группа"
                                    Width="*"/>

                <DataGridTextColumn Header="Дата начала"
                                    Width="150"/>

                <DataGridTextColumn Header="Дата окончания"
                                    Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Page>