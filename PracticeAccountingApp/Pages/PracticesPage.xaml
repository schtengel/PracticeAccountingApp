<Page x:Class="PracticeAccountingApp.Pages.PracticesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource PrimaryBrush}">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="28,24,28,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ведомости практик" 
                   Style="{StaticResource PageTitleText}" Margin="0 0 0 12"/>

        <!-- Action Bar -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Width="360" HorizontalAlignment="Left"
                         Style="{StaticResource InputBox}"
                         Margin="0 0 12 0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Поиск по типу, модулю, преподавателю, группе"/>

                <Button Grid.Column="1"
                        Content="＋  Добавить ведомость"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding OpenAddCommand}"
                        Visibility="{Binding CanManagePractices,
                                    Converter={StaticResource BoolToVisibilityConverter}}"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding Practices}"
                      Style="{StaticResource ModernDataGrid}"
                      ScrollViewer.VerticalScrollBarVisibility="Hidden"
                      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                      ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                      CellStyle="{StaticResource DataGridCellStyle}"
                      x:Name="PracticesGrid">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource DataGridRowStyle}">
                        <!-- Двойной клик для редактирования (обработчик в code-behind: DataGridRow_MouseDoubleClick) -->
                        <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Тип практики"
                                        Binding="{Binding PracticeType}"
                                        Width="Auto"/>

                    <DataGridTextColumn Header="Модуль"
                                        Binding="{Binding ModuleName}"
                                        Width="Auto"/>

                    <DataGridTextColumn Header="Группа"
                                        Binding="{Binding Group}"
                                        Width="Auto"/>

                    <DataGridTextColumn Header="Преподаватель"
                                        Binding="{Binding TeacherName}"
                                        Width="Auto"/>

                    <DataGridTextColumn Header="Начало"
                                        Binding="{Binding Start, StringFormat=dd.MM.yyyy}"
                                        Width="Auto"/>

                    <DataGridTextColumn Header="Окончание"
                                        Binding="{Binding End, StringFormat=dd.MM.yyyy}"
                                        Width="Auto"/>

                    <!-- Колонка действий -->
                    <DataGridTemplateColumn Header="Действия" Width="160" IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            Visibility="{Binding DataContext.CanManagePractices,
                                                         RelativeSource={RelativeSource AncestorType=DataGrid},
                                                         Converter={StaticResource BoolToVisibilityConverter}}">

                                    <Button Content="✏"
                                            Style="{StaticResource GhostButton}"
                                            Padding="8,5" FontSize="14"
                                            ToolTip="Редактировать"
                                            Command="{Binding DataContext.EditCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>

                                    <Button Content="🗑"
                                            Style="{StaticResource DangerButton}"
                                            Padding="8,5" FontSize="14"
                                            ToolTip="Удалить"
                                            Command="{Binding DataContext.DeleteCommand,
                                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Page>
