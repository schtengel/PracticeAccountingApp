<Page x:Class="PracticeAccountingApp.Pages.StatementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel>

            <TextBlock Text="Ведомости практик"
                       FontSize="24"
                       FontWeight="SemiBold"/>

            <Button Content="Создать ведомость"
                    Width="170"
                    HorizontalAlignment="Right"/>

        </DockPanel>

        <DataGrid Grid.Row="1"
                  Margin="0,20,0,0"
                  AutoGenerateColumns="False">

            <DataGrid.Columns>

                <DataGridTextColumn Header="№"
                                    Width="70"/>

                <DataGridTextColumn Header="Практика"
                                    Width="2*"/>

                <DataGridTextColumn Header="Группа"
                                    Width="150"/>

                <DataGridTextColumn Header="Организация"
                                    Width="2*"/>

                <DataGridTextColumn Header="Дата"
                                    Width="150"/>

                <DataGridTextColumn Header="Статус"
                                    Width="150"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>

</Page>