<Window x:Class="PracticeAccountingApp.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PracticeAccountingApp"
        Title="Авторизация — МЦПК" 
        Height="680" Width="1120"
        ResizeMode="NoResize" 
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.1*"/>
            <ColumnDefinition Width="2.9*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая декоративная панель -->
        <Border Grid.Column="0" Background="{StaticResource SecondaryBrush}">
            <Grid Margin="60">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="МЦПК" 
                               FontSize="52" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AccentBrush}"/>
                    <TextBlock Text="Учет ведомостей по практикам" 
                               FontSize="24" 
                               Margin="0,12,0,0" 
                               Foreground="{StaticResource TextBrush}"/>
                    <Border Height="1" Margin="0,40,0,30" Background="{StaticResource BorderBrush}"/>
                    <TextBlock Text="Система учета студентов, практик и отчетов" 
                               FontSize="16" 
                               TextWrapping="Wrap" 
                               Width="380" 
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Правая форма входа -->
        <Grid Grid.Column="1">
            <Border Width="460" Padding="40" 
                    Background="{StaticResource SecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="16" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">

                <StackPanel>
                    <TextBlock Text="Вход в систему" 
                               FontSize="28" 
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,32" 
                               Foreground="{StaticResource TextBrush}"/>

                    <!-- Логин -->
                    <TextBlock Text="Логин" 
                               Margin="4,0,0,6" 
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" 
                               Margin="4,16,0,6" 
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 Style="{StaticResource PasswordBoxStyle}"/>

                    <!-- Сообщение об ошибке -->
                    <TextBlock Text="{Binding ErrorMessage}" 
                               Foreground="#D32F2F" 
                               FontSize="14.5" 
                               Margin="4,10,4,4"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               FontWeight="Medium"/>

                    <!-- Кнопки -->
                    <StackPanel Margin="0,20,0,0">
                        <Button Content="Войти" 
                                Height="48" 
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoginUserCommand}"
                                CommandParameter="{Binding ElementName=PasswordBox}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"/>

                        <Button Content="Войти как гость" 
                                Height="46" 
                                Margin="0,12,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoginAsGuestCommand}"/>
                    </StackPanel>

                    <!-- Индикатор загрузки -->
                    <ProgressBar IsIndeterminate="True" 
                                 Height="3" 
                                 Margin="0,18,0,0"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>