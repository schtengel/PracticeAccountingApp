<Window x:Class="PracticeAccountingApp.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="650"
        Width="1100"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*"/>
            <ColumnDefinition Width="2.8*"/>
        </Grid.ColumnDefinitions>

        <!-- ЛЕВАЯ ПАНЕЛЬ -->

        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}">

            <Grid Margin="50">

                <StackPanel VerticalAlignment="Center">

                    <TextBlock Text="МЦПК"
                               FontSize="48"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>

                    <TextBlock Text="Учет ведомостей по практикам"
                               Margin="0,10,0,0"
                               FontSize="22"
                               Foreground="{StaticResource TextBrush}"/>

                    <Border Height="1"
                            Margin="0,30,0,30"
                            Background="{StaticResource BorderBrush}"/>

                    <TextBlock Text="Система предназначена для учета студентов, практик, организаций и ведомостей."
                               FontSize="16"
                               HorizontalAlignment="Left"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Width="350"/>

                </StackPanel>

            </Grid>

        </Border>

        <!-- ПРАВАЯ ЧАСТЬ -->

        <Grid Grid.Column="1">

            <Border Width="460"
                    Padding="40"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{StaticResource SecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->

                    <TextBlock Grid.Row="0"
                               Text="Вход в систему"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <!-- Логин -->

                    <TextBlock Grid.Row="1"
                               Text="Логин"
                               Foreground="{StaticResource TextBrush}"
                               Margin="10"/>

                    <TextBox Grid.Row="2"
                             Style="{StaticResource InputBox}"
                             Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Пароль -->

                    <TextBlock Grid.Row="3"
                               Text="Пароль"
                               Foreground="{StaticResource TextBrush}"
                               Margin="10"/>

                    <PasswordBox Grid.Row="4"
                                 x:Name="PasswordBox"
                                 Style="{StaticResource PasswordBoxStyle}"/>

                    <!-- Кнопки -->

                    <StackPanel Grid.Row="5"
                                Margin="0,25,0,0">

                        <Button Content="Войти"
                                Height="42"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding LoginUserCommand}"
                                CommandParameter="{Binding ElementName=PasswordBox}"/>

                        <Button Content="Войти как гость"
                                Height="42"
                                Margin="0,10,0,0"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding LoginAsGuestCommand}"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>