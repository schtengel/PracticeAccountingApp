<Window x:Class="PracticeAccountingApp.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="600"
        Width="1000"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#D9BC9A">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>


        <Border Grid.Column="0"
                Background="#403B35">

            <Grid>

                <StackPanel VerticalAlignment="Center"
                            Margin="40">

                    <TextBlock Text="МЦПК"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="#BF996A"/>

                    <TextBlock Text="Учет ведомостей по практикам"
                               FontSize="20"
                               Margin="0,10,0,0"
                               Foreground="White"/>

                    <Separator Margin="0,25"/>

                    <TextBlock Text="Система предназначена для ведения учета студентов, практик, организаций и ведомостей."
                               TextWrapping="Wrap"
                               FontSize="16"
                               Foreground="#D9BC9A"/>

                </StackPanel>

            </Grid>

        </Border>


        <Grid Grid.Column="1">

            <Border Width="420"
                    Background="White"
                    CornerRadius="20"
                    Padding="35"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Вход в систему"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#403B35"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,30"/>

                    <TextBlock Grid.Row="1"
                               Text="Логин"
                               FontSize="14"
                               Margin="0,0,0,5"/>

                    <TextBox Grid.Row="2"
                             x:Name="LoginTextBox"
                             Height="40"
                             FontSize="14"
                             Padding="10"/>

                    <TextBlock Grid.Row="3"
                               Text="Пароль"
                               FontSize="14"
                               Margin="0,20,0,5"/>

                    <PasswordBox Grid.Row="4"
                                 x:Name="PasswordBox"
                                 Height="40"
                                 FontSize="14"
                                 Padding="10"/>

                    <StackPanel Grid.Row="5"
                                Margin="0,30,0,0">

                        <Button x:Name="LoginButton"
                                Content="Войти"
                                Height="45"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Background="#403B35"
                                Foreground="White"
                                BorderThickness="0"
                                Click="LoginButton_Click"/>

                        <Button x:Name="ExitButton"
                                Content="Войти как гость"
                                Height="45"
                                Margin="0,10,0,0"
                                FontSize="15"
                                Foreground="#BF996A"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="LoginAsGuestButton_Click"/>

                    </StackPanel>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>

