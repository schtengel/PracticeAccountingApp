<Window x:Class="PracticeAccountingApp.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация"
        Height="600"
        Width="1000"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}">

            <StackPanel VerticalAlignment="Center"
                        Margin="40">

                <TextBlock Text="МЦПК"
                           FontSize="42"
                           FontWeight="Bold"
                           Foreground="{StaticResource AccentBrush}"/>

                <TextBlock Text="Учет ведомостей по практикам"
                           FontSize="20"
                           Margin="0,10,0,0"
                           Foreground="White"/>

                <Separator Margin="0,25"/>

                <TextBlock Text="Система предназначена для ведения учета студентов, практик, организаций и ведомостей."
                           TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="{StaticResource LightBrush}"/>

            </StackPanel>

        </Border>

        <Border Grid.Column="1"
                Width="420"
                Background="White"
                CornerRadius="20"
                Padding="35"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Вход в систему"
                           Style="{StaticResource PageTitle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <TextBlock Grid.Row="1" Text="Логин"/>
                <TextBox Grid.Row="2"
                         Style="{StaticResource InputBox}"
                         Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Grid.Row="3"
                           Text="Пароль"
                           Margin="0,10,0,5"/>

                <PasswordBox Grid.Row="4"
                             x:Name="PasswordBox"
                             Style="{StaticResource PasswordBoxStyle}"/>

                <StackPanel Grid.Row="5"
                            Margin="0,20,0,0">

                    <Button Content="Войти"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginUserCommand}"
                            CommandParameter="{Binding ElementName=PasswordBox}"/>

                    <Button Content="Войти как гость"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding LoginAsGuestCommand}"/>

                </StackPanel>

            </Grid>

        </Border>

    </Grid>
</Window>