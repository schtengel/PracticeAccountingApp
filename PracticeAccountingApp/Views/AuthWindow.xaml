<Window x:Class="PracticeAccountingApp.Views.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PracticeAccountingApp"
        Title="Авторизация — МЦПК"
        Height="680" Width="1100"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="{StaticResource PrimaryBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <local:InvertBoolConverter x:Key="InvertBoolConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Левая панель — брендинг ═══ -->
        <Border Grid.Column="0" Background="{StaticResource AccentBrush}">
            <Grid Margin="52">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="МЦПК"
                               FontSize="56" FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Учёт ведомостей&#10;по практикам"
                               FontSize="22" LineHeight="34"
                               Margin="0,14,0,0"
                               Foreground="#FFE8EE"
                               TextWrapping="Wrap"/>

                    <Border Height="1" Margin="0,36,0,28"
                            Background="#FFFFFF" Opacity="0.2"/>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="✓" Foreground="#FFE8EE" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Управление группами и студентами"
                                       Foreground="#FFE8EE" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="✓" Foreground="#FFE8EE" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Учёт практик и ведомостей"
                                       Foreground="#FFE8EE" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✓" Foreground="#FFE8EE" FontSize="14" Margin="0,0,10,0"/>
                            <TextBlock Text="Отчёты студентов"
                                       Foreground="#FFE8EE" FontSize="14"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Правая панель — форма ═══ -->
        <Grid Grid.Column="1" Background="{StaticResource PrimaryBrush}">
            <Border Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <!-- Заголовок -->
                    <TextBlock Text="Добро пожаловать"
                               FontSize="28" FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Войдите в систему для продолжения"
                               FontSize="14" Margin="0,8,0,36"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"/>

                    <!-- Логин -->
                    <TextBlock Text="Логин" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" Style="{StaticResource LabelText}" Margin="2,16,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource PasswordBoxStyle}"/>

                    <!-- Ошибка -->
                    <Border Margin="0,12,0,0" Padding="12,10"
                            Background="#FFF5F5" CornerRadius="8"
                            Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚠ " Foreground="#C0392B" FontSize="13"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#C0392B" FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Кнопки -->
                    <Button Content="Войти"
                            Height="46" Margin="0,20,0,0"
                            Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginUserCommand}"
                            CommandParameter="{Binding ElementName=PasswordBox}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InvertBoolConverter}}"/>

                    <Button Content="Войти как гость"
                            Height="44" Margin="0,10,0,0"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding LoginAsGuestCommand}"/>

                    <!-- Загрузка -->
                    <Grid Margin="0,16,0,0" Height="20"
                          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True" Height="3"
                                     VerticalAlignment="Top"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="Transparent"/>
                        <TextBlock Text="Проверка данных..."
                                   FontSize="12"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
