<Window x:Class="PracticeAccountingApp.Views.CreateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание пользователя"
        Height="480" Width="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PrimaryBrush}">

    <Border Margin="20" Background="{StaticResource SecondaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="14" Padding="28">

        <StackPanel>
            <TextBlock Text="Новый пользователь"
                       Style="{StaticResource SectionTitleText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- Логин -->
            <TextBlock Text="Логин" Style="{StaticResource LabelText}"/>
            <TextBox Style="{StaticResource InputBox}"
                     Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Пароль -->
            <!-- Синхронизация Password ↔ VM выполняется в code-behind через
                 PasswordBox.PasswordChanged → vm.Password = passwordBox.Password -->
            <TextBlock Text="Пароль" Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
            <PasswordBox x:Name="PasswordBox"
                         Style="{StaticResource PasswordBoxStyle}"
                         PasswordChanged="PasswordBox_PasswordChanged"/>

            <!-- Роль -->
            <TextBlock Text="Роль" Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
            <ComboBox Style="{StaticResource ComboBoxInput}"
                      ItemsSource="{Binding Roles}"
                      SelectedItem="{Binding SelectedRole}"
                      DisplayMemberPath="RoleName"/>

            <Button Content="Создать пользователя"
                    Height="44" Margin="0,24,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding CreateUserCommand}"/>
        </StackPanel>
    </Border>
</Window>
