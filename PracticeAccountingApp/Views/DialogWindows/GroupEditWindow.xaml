<Window x:Class="PracticeAccountingApp.Views.DialogWindows.GroupEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Группа"
        Height="700" Width="650"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PrimaryBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Border Margin="20" Background="{StaticResource SecondaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="14" Padding="28">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Данные группы"
                           Style="{StaticResource SectionTitleText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <!-- Номер группы: Style задаётся только внутри TextBox.Style (BasedOn),
                     чтобы избежать дублирования атрибута Style. -->
                <TextBlock Text="Номер группы" Style="{StaticResource LabelText}"/>
                <TextBox Text="{Binding GroupNumber, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsNewGroup}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource InputBox}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsNewGroup}" Value="False">
                                    <Setter Property="Opacity" Value="0.6"/>
                                    <Setter Property="ToolTip"
                                            Value="Номер группы нельзя изменить после создания"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock Text="Специальность"
                           Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding Specialization, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Курс"
                           Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
                <ComboBox Style="{StaticResource ComboBoxInput}"
                          ItemsSource="{Binding AvailableCourses}"
                          SelectedItem="{Binding Course}"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Text="Студенты группы"
                           Style="{StaticResource LabelText}"
                           FontSize="13" Margin="2,0,0,8"/>

                <Border BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <DataGrid ItemsSource="{Binding StudentsInGroup}"
                              Style="{StaticResource ModernDataGrid}"
                              ColumnHeaderStyle="{StaticResource DataGridColumnHeaderStyle}"
                              CellStyle="{StaticResource DataGridCellStyle}"
                              RowStyle="{StaticResource DataGridRowStyle}"
                              MaxHeight="180"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ФИО"
                                                Binding="{Binding FullName}" Width="*"/>
                            <DataGridTextColumn Header="Дата рождения"
                                                Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}"
                                                Width="140"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </StackPanel>

            <Button Grid.Row="2"
                    Content="Сохранить"
                    Height="44" Margin="0,16,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>
    </Border>
</Window>
