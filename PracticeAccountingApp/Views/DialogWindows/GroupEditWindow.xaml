<Window x:Class="PracticeAccountingApp.Views.DialogWindows.GroupEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование группы" 
        Height="680" Width="620"
        MinHeight="620" MinWidth="580"
        WindowStartupLocation="CenterScreen" 
        Background="{StaticResource PrimaryBrush}">

    <Border Margin="24" Background="{StaticResource SecondaryBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="16" Padding="32">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Редактирование группы" 
                           Style="{StaticResource SectionTitleText}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Номер группы" Margin="4,0,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBox Style="{StaticResource InputBox}" Text="{Binding GroupNumber}"/>

                <TextBlock Text="Специальность" Margin="4,16,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBox Style="{StaticResource InputBox}" Text="{Binding Specialization}"/>

                <TextBlock Text="Курс" Margin="4,16,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <ComboBox Style="{StaticResource ComboBoxInput}"
                          ItemsSource="{Binding AvailableCourses}"
                          SelectedItem="{Binding Course}"/>
            </StackPanel>

            <!-- Таблица студентов группы -->
            <GroupBox Grid.Row="1" Header="Студенты в группе" Margin="0,24,0,12" Padding="12">
                <DataGrid ItemsSource="{Binding StudentsInGroup}" 
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Background="{StaticResource PrimaryBrush}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"/>
                        <DataGridTextColumn Header="Дата рождения" Binding="{Binding BirthDate, StringFormat=dd.MM.yyyy}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <Button Grid.Row="2" Content="Сохранить" 
                    VerticalAlignment="Bottom"
                    Height="48" Margin="0,20,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </Grid>
    </Border>
</Window>