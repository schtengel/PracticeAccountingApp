<Window x:Class="PracticeAccountingApp.Views.DialogWindows.PracticeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ведомость практики"
        Height="650" Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PrimaryBrush}">

    <Border Margin="20" Background="{StaticResource SecondaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="14" Padding="28">

        <StackPanel>
            <TextBlock Text="Данные ведомости"
                       Style="{StaticResource SectionTitleText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <TextBlock Text="Тип практики" Style="{StaticResource LabelText}"/>
            <ComboBox Style="{StaticResource ComboBoxInput}"
                      ItemsSource="{Binding PracticeTypes}"
                      SelectedItem="{Binding SelectedPracticeType}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding PracticeTypeName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Модуль" Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
            <ComboBox Style="{StaticResource ComboBoxInput}"
                      ItemsSource="{Binding Modules}"
                      SelectedItem="{Binding SelectedModule}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding ModuleName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Преподаватель" Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
            <ComboBox Style="{StaticResource ComboBoxInput}"
                      ItemsSource="{Binding Teachers}"
                      SelectedItem="{Binding SelectedTeacher}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="Группа" Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
            <ComboBox Style="{StaticResource ComboBoxInput}"
                      ItemsSource="{Binding Groups}"
                      SelectedItem="{Binding SelectedGroup}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding GroupNumber}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Даты -->
            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Дата начала (дд.мм.гггг)" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding StartString, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Дата окончания (дд.мм.гггг)" Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding EndString, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <Button Content="Сохранить"
                    Height="44" Margin="0,28,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Border>
</Window>