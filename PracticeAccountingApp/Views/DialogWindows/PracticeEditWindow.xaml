<Window x:Class="PracticeAccountingApp.Views.DialogWindows.PracticeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование практики" Height="720" Width="540"
        WindowStartupLocation="CenterScreen" Background="{StaticResource PrimaryBrush}">

    <Border Margin="24" Background="{StaticResource SecondaryBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="16" Padding="32">

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Практика" Style="{StaticResource SectionTitleText}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>

                <TextBlock Text="Тип практики" Margin="4,0,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <ComboBox ItemsSource="{Binding PracticeTypes}" Style="{StaticResource ComboBoxInput}"
                          DisplayMemberPath="PracticeTypeName" SelectedItem="{Binding SelectedPracticeType}"/>

                <TextBlock Text="Модуль" Margin="4,16,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <ComboBox ItemsSource="{Binding Modules}" Style="{StaticResource ComboBoxInput}"
                          DisplayMemberPath="ModuleName" SelectedItem="{Binding SelectedModule}"/>

                <TextBlock Text="Преподаватель" Margin="4,16,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <ComboBox ItemsSource="{Binding Teachers}" Style="{StaticResource ComboBoxInput}"
                          DisplayMemberPath="FullName" SelectedItem="{Binding SelectedTeacher}"/>

                <TextBlock Text="Группа" Margin="4,16,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <ComboBox ItemsSource="{Binding Groups}" Style="{StaticResource ComboBoxInput}"
                          DisplayMemberPath="GroupNumber" SelectedItem="{Binding SelectedGroup}"/>

                <TextBlock Text="Дата начала (дд.мм.гггг)" Margin="4,16,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBox Style="{StaticResource InputBox}" Text="{Binding StartString}"/>

                <TextBlock Text="Дата окончания (дд.мм.гггг)" Margin="4,16,0,6" Foreground="{StaticResource MutedTextBrush}"/>
                <TextBox Style="{StaticResource InputBox}" Text="{Binding EndString}"/>

                <Button Content="Сохранить" Margin="0,32,0,0" Height="46"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding SaveCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>