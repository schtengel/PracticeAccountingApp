<Window x:Class="PracticeAccountingApp.Views.DialogWindows.StudentReportEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчёт студента"
        Height="560" Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PrimaryBrush}">

    <Border Margin="20" Background="{StaticResource SecondaryBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            CornerRadius="14" Padding="28">

        <StackPanel>
            <TextBlock Text="Данные отчёта"
                       Style="{StaticResource SectionTitleText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"/>

            <!-- Студент -->
            <!-- Студент -->
            <TextBlock Text="Студент" Style="{StaticResource LabelText}"/>
            <ComboBox Style="{StaticResource ComboBoxInput}"
          ItemsSource="{Binding Students}"
          SelectedItem="{Binding SelectedStudent}">

                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>

            </ComboBox>

            <!-- Ведомость -->
            <TextBlock Text="Ведомость практики"
                       Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
            <ComboBox Style="{StaticResource ComboBoxInput}"
                      ItemsSource="{Binding PracticeSheets}"
                      SelectedItem="{Binding SelectedPracticeSheet}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <!-- Показываем: тип практики + группа + дата начала -->
                        <TextBlock>
                            <Run Text="{Binding PracticeType.PracticeTypeName}"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding GroupNumber}"/>
                            <Run Text=" ("/>
                            <Run Text="{Binding StartDate, StringFormat=dd.MM.yyyy}"/>
                            <Run Text=")"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Файл отчёта -->
            <TextBlock Text="Файл отчёта"
                       Style="{StaticResource LabelText}" Margin="2,14,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Style="{StaticResource InputBox}"
                         Text="{Binding FilePath, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"
                         ToolTip="{Binding FilePath}"/>

                <Button Grid.Column="2"
                        Content="Обзор…"
                        Style="{StaticResource SecondaryButton}"
                        Padding="14,0"
                        Command="{Binding BrowseFileCommand}"/>
            </Grid>

            <!-- Оценка и дата в одну строку -->
            <Grid Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Оценка (2–5)"
                               Style="{StaticResource LabelText}"/>
                    <ComboBox Style="{StaticResource ComboBoxInput}"
                              ItemsSource="{Binding GradeOptions}"
                              SelectedItem="{Binding GradeString}"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Дата сдачи (дд.мм.гггг)"
                               Style="{StaticResource LabelText}"/>
                    <TextBox Style="{StaticResource InputBox}"
                             Text="{Binding SubmissionDateString, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>

            <Button Content="Сохранить"
                    Height="44" Margin="0,28,0,0"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Border>
</Window>
