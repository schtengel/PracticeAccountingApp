<Window x:Class="PracticeAccountingApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет ведомостей по практикам"
        Height="800"
        Width="1200"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->

        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->

                <StackPanel Margin="24">

                    <TextBlock Text="МЦПК"
                               FontSize="42"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>

                    <TextBlock Text="Учет практик"
                               FontSize="14"
                               Margin="0,4,0,0"
                               Foreground="{StaticResource MutedTextBrush}"/>

                </StackPanel>

                <!-- NAVIGATION -->

                <ListBox Grid.Row="1"
                         x:Name="NavigationMenu"
                         Margin="10,0"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource NavigationItemStyle}"
                         SelectionChanged="NavigationMenu_SelectionChanged">

                    <ListBoxItem Tag="Pages/HomePage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠"
                                       FontSize="16"/>
                            <TextBlock Text="Главная"
                                       FontSize="18"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/StudentsPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎓"
                                       FontSize="16"/>
                            <TextBlock Text="Студенты"
                                       FontSize="18"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/GroupsPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥"
                                       FontSize="16"/>
                            <TextBlock Text="Группы"
                                       FontSize="18"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/PracticesPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📚"
                                       FontSize="16"/>
                            <TextBlock Text="Ведомости"
                                       FontSize="18"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/ReportsPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄"
                                       FontSize="16"/>
                            <TextBlock Text="Отчеты"
                                       FontSize="18"
                                       Margin="12,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                </ListBox>

                <!-- USER PANEL -->

                <Border Grid.Row="2"
                        Margin="15"
                        Padding="15"
                        Background="{StaticResource SecondaryBrush}"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">

                    <StackPanel>

                        <TextBlock Text="Пользователь"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextBrush}"/>

                        <TextBlock Text="{Binding CurrentUser.Login}"
                                   Margin="0,5,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Border>

        <!-- CONTENT -->

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="75"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP BAR -->

            <Border Grid.Row="0"
                    Background="{StaticResource SecondaryBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1">

                <Grid Margin="25,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Учет ведомостей по практикам"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"/>
                    
                    

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Button Content="Создать пользователя"
                                Margin="10,0,10,0"
                                Width="150"
                                Style="{StaticResource SecondaryButton}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OpenCreateUser"/>

                        <Border Width="40"
                                Height="40"
                                CornerRadius="20"
                                Background="{StaticResource AccentBrush}">

                            <TextBlock Text="👤"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                        </Border>

                        <Button Content="Выйти"
                                Margin="10,0,0,0"
                                Width="100"
                                Style="{StaticResource SecondaryButton}"
                                Click="LogOutButton_Click"/>

                        

                    </StackPanel>

                </Grid>

            </Border>

            <!-- PAGE CONTENT -->

            <Border Grid.Row="1"
                    Margin="20"
                    Background="{StaticResource BackgroundBrush}"
                    CornerRadius="12">

                <Frame x:Name="MainFrame"
                       NavigationUIVisibility="Hidden"
                       Background="Transparent"/>

            </Border>

        </Grid>

    </Grid>

</Window>