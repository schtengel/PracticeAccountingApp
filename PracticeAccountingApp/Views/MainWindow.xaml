<Window x:Class="PracticeAccountingApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Учет ведомостей по практикам"
        Height="1080"
        Width="1920"
        MinHeight="500"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="{StaticResource PrimaryBrush}">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="20">
                    <TextBlock Text="МЦПК"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"/>

                    <TextBlock Text="Учет практик"
                               FontSize="13"
                               Foreground="{StaticResource LightBrush}"/>
                </StackPanel>

                <ListBox Grid.Row="1"
                         x:Name="NavigationMenu"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource NavigationItemStyle}"
                         SelectionChanged="NavigationMenu_SelectionChanged">

                    <ListBoxItem Tag="Pages/HomePage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠"/>
                            <TextBlock Text="Главная" Margin="10,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/StudentsPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎓"/>
                            <TextBlock Text="Студенты" Margin="10,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/GroupsPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👥"/>
                            <TextBlock Text="Группы" Margin="10,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/PracticesPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📚"/>
                            <TextBlock Text="Практики" Margin="10,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/StatementsPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋"/>
                            <TextBlock Text="Ведомости" Margin="10,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                    <ListBoxItem Tag="Pages/ReportsPage.xaml">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📄"/>
                            <TextBlock Text="Отчеты" Margin="10,0,0,0"/>
                        </StackPanel>
                    </ListBoxItem>

                </ListBox>

            </Grid>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource LightBrush}">

                <Grid Margin="25,0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Учет ведомостей по практикам"
                               VerticalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Ellipse Width="36"
                                 Height="36"
                                 Fill="{StaticResource PrimaryBrush}"/>

                        <Button Content="Выйти"
                                Style="{StaticResource GhostButton}"
                                Margin="16,0,0,0"
                                Click="LogOutButton_Click"/>

                        <Button Content="Создать пользователя"
                                Style="{StaticResource PrimaryButton}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="OpenCreateUser"/>

                    </StackPanel>

                </Grid>

            </Border>

            <Frame Grid.Row="1"
                   x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{StaticResource BackgroundBrush}"/>

        </Grid>

    </Grid>
</Window>